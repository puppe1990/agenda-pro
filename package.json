{
  "name": "agenda-pro",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "pnpm --filter @agenda-pro/app dev",
    "dev:app": "pnpm --filter @agenda-pro/app dev",
    "dev:landing": "pnpm --filter @agenda-pro/landing dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @agenda-pro/app test:e2e",
    "verify": "pnpm format:check && pnpm lint && pnpm -r verify",
    "verify:full": "pnpm verify && pnpm test:e2e",
    "db:generate": "pnpm --filter @agenda-pro/app db:generate",
    "db:migrate": "pnpm --filter @agenda-pro/app db:migrate",
    "db:push": "pnpm --filter @agenda-pro/app db:push",
    "db:seed": "pnpm --filter @agenda-pro/app db:seed",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{css,js,json,jsx,md,mjs,ts,tsx,yaml,yml}": [
      "prettier --write"
    ],
    "*.{js,jsx,mjs,ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ]
  }
}
